datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum DriverApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  BLOCKED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  SUSPENDED
  UNAVAILABLE
  ARCHIVED
}

enum RideStatus {
  SCHEDULED
  REQUESTED
  ACCEPTED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Set when the user deletes their account. The row is kept (anonymized,
  // not hard-deleted) so existing rides still resolve their counterpart's
  // name/rating - email/name/phone are scrubbed and the password hash is
  // replaced with an unusable random value at that point.
  deletedAt DateTime?

  // Driver-only fields. Left null for CLIENT rows. Kept on User (rather than a
  // separate DriverProfile table) because it's a strict 1:1 relation and
  // location pings are a high-frequency hot path where a join isn't worth it.
  isAvailable           Boolean?  @default(false)
  currentLat            Float?
  currentLng            Float?
  lastLocationUpdatedAt DateTime?

  // Vehicle info collected at driver registration. Plate is required for a
  // DRIVER (enforced in the registration validator, not the DB, since CLIENT/
  // ADMIN rows never have one); model is optional. Separate from the
  // admin-managed Vehicle/VehicleAssignment fleet records (see below) -
  // these stay as the mobile app's own self-reported fields, untouched by
  // the admin back office.
  vehiclePlate String?
  vehicleModel String?

  // Set to PENDING for a new DRIVER at registration, null for CLIENT/ADMIN.
  // A driver can't go online or accept rides until an admin sets this to
  // APPROVED (see user.service.js#updateAvailability, ride.service.js#acceptRide).
  // SUSPENDED/BLOCKED are admin-set operational states: both already fail the
  // `!== 'APPROVED'` checks above (blocking availability/ride-acceptance)
  // with no extra code; BLOCKED additionally denies login/refresh/requireAuth
  // entirely (see auth.service.js, auth.middleware.js).
  approvalStatus DriverApprovalStatus?
  approvedAt     DateTime?

  // Extended driver profile (admin back office, Phase 1). All optional -
  // existing rows get null until an admin fills them in. Document/photo
  // fields are plain URLs for a future object-storage integration; no
  // upload pipeline exists yet, this pass doesn't build one.
  address            String?
  nationalId         String?
  licenseNumber      String?
  licenseExpiryAt    DateTime?
  contractType       String?
  // Captured once at driver creation as a historical record of the starting
  // balance; not editable afterward. The live, spendable balance is the
  // existing `creditBalance` field below, which this seeds at creation time.
  initialBalance     Float?    @default(0)
  photoUrl           String?
  idDocumentUrl      String?
  licenseDocumentUrl String?

  // Driver's current commission rate (fraction 0..1, e.g. 0.20 = 20%).
  // Null for non-drivers. The only way this changes is
  // admin.service.js#setCommissionRate, which also writes a CommissionChange
  // row - so a ride's frozen commissionRateSnapshot (see Ride below) can
  // never silently drift out of sync with an unrecorded rate change.
  commissionRate Float?

  // Running average across all ratings received (as a driver or as a client -
  // whichever role this user has). Updated incrementally when a rating comes in.
  ratingAverage Float?
  ratingCount   Int    @default(0)

  // Expo push token for this user's current device. Nullable - not every
  // user grants notification permission, and it's cleared on logout.
  pushToken String?

  // Referral program. This user's own shareable code (assigned at
  // registration; nullable rather than a NOT NULL migration since existing
  // rows are backfilled by a one-off script instead). referredById is set at
  // registration if they signed up with someone else's code.
  referralCode String? @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  // Cash-equivalent balance, auto-applied to a future ride's cash payment
  // (see Ride.creditApplied). Funded by referral rewards.
  creditBalance Float @default(0)
  // Set once this user's own "referred friend's first ride" reward has been
  // granted, so it's never granted twice even across many later rides.
  referralRewardGrantedAt DateTime?

  ridesAsClient Ride[] @relation("ClientRides")
  ridesAsDriver Ride[] @relation("DriverRides")
  refreshTokens RefreshToken[]

  commissionChangesReceived CommissionChange[] @relation("CommissionChangeDriver")
  commissionChangesMade     CommissionChange[] @relation("CommissionChangeAdmin")
  vehicleAssignments        VehicleAssignment[]
  currentVehicles           Vehicle[]           @relation("VehicleCurrentDriver")

  @@index([role, isAvailable])
  @@map("users")
}

// History of commissionRate changes on User (spec 9.3) - written every time
// admin.service.js#setCommissionRate changes a driver's rate, so past rate
// changes stay auditable even though User only stores the current rate.
model CommissionChange {
  id              String   @id @default(uuid())
  driverId        String
  driver          User     @relation("CommissionChangeDriver", fields: [driverId], references: [id])
  oldRate         Float?
  newRate         Float
  reason          String?
  changedByUserId String
  changedByUser   User     @relation("CommissionChangeAdmin", fields: [changedByUserId], references: [id])
  changedAt       DateTime @default(now())

  @@index([driverId])
  @@map("commission_changes")
}

// Admin-managed fleet record, additive next to User.vehiclePlate/vehicleModel
// (the mobile app's own self-reported fields, left untouched).
model Vehicle {
  id        String  @id @default(uuid())
  brand     String
  model     String
  plate     String  @unique
  color     String?
  year      Int?
  type      String?
  seatCount Int?

  insuranceProvider  String?
  insuranceNumber    String?
  insuranceExpiresAt DateTime?

  carteGriseNumber             String?
  technicalInspectionExpiresAt DateTime?

  status VehicleStatus @default(ACTIVE)

  // Denormalized "current driver" pointer for hot-path reads, kept in sync
  // exclusively by vehicle.service.js#assignVehicle/#unassignVehicle - the
  // source of truth for *history* is VehicleAssignment below.
  currentDriverId String?
  currentDriver   User?   @relation("VehicleCurrentDriver", fields: [currentDriverId], references: [id])

  assignments VehicleAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentDriverId])
  @@map("vehicles")
}

// Vehicle<->driver assignment history (spec 5.3). Assigning a vehicle closes
// any row with endDate: null for that vehicle, then opens a new one - see
// vehicle.service.js#assignVehicle.
model VehicleAssignment {
  id        String    @id @default(uuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId  String
  driver    User      @relation(fields: [driverId], references: [id])
  startDate DateTime  @default(now())
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([driverId])
  @@index([vehicleId, endDate])
  @@map("vehicle_assignments")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Ride {
  id       String  @id @default(uuid())
  clientId String
  client   User    @relation("ClientRides", fields: [clientId], references: [id])
  driverId String?
  driver   User?   @relation("DriverRides", fields: [driverId], references: [id])

  status RideStatus @default(REQUESTED)

  pickupLat          Float
  pickupLng          Float
  pickupAddress      String?
  destinationLat     Float
  destinationLng     Float
  destinationAddress String?

  distanceKm    Float?
  durationMin   Float?
  estimatedFare Float?
  // Road-network route from OSRM as an array of [lat, lng] pairs, for drawing
  // the actual path on the map. Null if OSRM was unreachable when the ride
  // was requested (distance/duration then fall back to a straight-line estimate).
  routeGeometry Json?

  // Set only for a booked-ahead ride (status starts at SCHEDULED). Null for
  // an immediate request. The scheduling job (src/jobs/scheduling.job.js)
  // flips SCHEDULED -> REQUESTED (and resets requestedAt to that moment) once
  // within SCHEDULED_RIDE_ACTIVATION_LEAD_MIN of this time, at which point it
  // behaves exactly like a normal ride request.
  scheduledFor DateTime?

  requestedAt DateTime  @default(now())
  acceptedAt  DateTime?
  arrivedAt   DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  cancelledBy        Role?
  cancellationReason String?

  // Drivers who declined this ride (see ride.service.js#declineRide). Status
  // stays REQUESTED - a decline only hides the request from that one driver,
  // it doesn't remove it for the other nearby drivers it was broadcast to.
  declinedByDriverIds String[] @default([])

  // Chosen by the client at request time. Still no online gateway - the
  // driver confirms collection manually either way, this just records intent.
  paymentMethod PaymentMethod @default(CASH)

  // The driver marks a completed ride as paid once they've collected payment
  // in person (CASH rides). For CARD rides, isPaid/paidAt are instead set by
  // the Stripe webhook once the client completes an online Checkout Session.
  isPaid Boolean   @default(false)
  paidAt DateTime?

  // Set once the client starts (session id) / completes (payment intent id) a
  // Stripe Checkout Session for this ride. Null for CASH rides and for CARD
  // rides where payment hasn't been attempted yet.
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  // How much of the client's referral credit balance was auto-deducted
  // toward this ride at completion - the driver should only collect
  // (estimatedFare - creditApplied) in cash, not the full estimate.
  creditApplied Float @default(0)

  // Frozen at the moment this ride reaches COMPLETED (see
  // ride.service.js#snapshotCommission), using the driver's commissionRate
  // AT THAT MOMENT - a later change to the driver's rate must never
  // retroactively alter an already-completed ride's numbers. Stored as real
  // columns (not derived at read time) so admin.service.js's revenue
  // aggregates can _sum them directly. commissionAmount is the company's
  // cut, driverNetAmount = estimatedFare - commissionAmount.
  commissionRateSnapshot Float?
  commissionAmount       Float?
  driverNetAmount        Float?

  // Per-user "trash": hiding a ride only removes it from that user's own
  // history list, the other participant and the ride record are unaffected.
  hiddenByClient Boolean @default(false)
  hiddenByDriver Boolean @default(false)

  // driverRating/-Comment = rating the CLIENT gave the DRIVER; clientRating/-Comment
  // = rating the DRIVER gave the CLIENT. Each side rates the other at most once,
  // only after the ride reaches COMPLETED.
  driverRating        Int?
  driverRatingComment String?
  clientRating        Int?
  clientRatingComment String?

  // Set once the periodic reminder job (see src/jobs/reminder.job.js) has
  // actually sent that reminder push, so a ride is only ever nudged once.
  searchReminderSentAt DateTime?
  ratingReminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([driverId])
  @@index([driverId, completedAt])
  @@map("rides")
}
