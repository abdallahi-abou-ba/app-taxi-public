datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum DriverApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  BLOCKED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  SUSPENDED
  UNAVAILABLE
  ARCHIVED
}

// Verification documents a DRIVER submits from the mobile app for an admin
// to review before approval (spec: driver "CV"/dossier check). One row per
// (driver, type) - see DriverDocument's @@unique - so a re-upload after a
// REJECTED status replaces the previous file rather than accumulating rows.
enum DriverDocumentType {
  PHOTO
  ID_CARD
  LICENSE
  VEHICLE_PHOTO
}

// Sub-role for a User with role=ADMIN only (null for CLIENT/DRIVER). Granular
// permissions (spec 11) are intentionally coarse - by back-office section,
// not per-action - since the client's spec doesn't call for finer control.
// SUPER_ADMIN bypasses every requirePermission() check unconditionally (see
// auth.middleware.js), so it's the only role that can also manage other
// admins' roles.
enum AdminRole {
  SUPER_ADMIN
  FINANCE
  OPERATIONS
  SUPPORT
}

// Spec 8.2's taxonomy, grouped by what the expense relates to (driver,
// vehicle, or the platform itself) - the group isn't a stored column, it's
// derived from the category via EXPENSE_CATEGORY_GROUPS in
// expense.constants.js, so category and group can never drift out of sync.
// OTHER is a deliberate addition beyond the spec's own list - it doesn't
// belong to any of the 3 groups, just a catch-all escape hatch.
enum ExpenseCategory {
  // Frais liés au chauffeur
  DRIVER_ADVANCE
  PENALTY
  UNIFORM
  TRAINING
  DOCUMENT_FEE
  COMMUNICATION
  // Frais liés au véhicule
  FUEL
  OIL_CHANGE
  REPAIR
  CAR_WASH
  INSURANCE
  TECHNICAL_INSPECTION
  TIRES
  MAINTENANCE
  SPARE_PARTS
  // Frais liés à la plateforme
  SERVER_HOSTING
  SMS
  INTERNET
  ADVERTISING
  CUSTOMER_SUPPORT
  PAYMENT_PROCESSING_FEE
  ADMIN_FEE
  // Catch-all, not part of the spec's 3 groups
  OTHER
}

// Spec 8.4: who ultimately bears an expense - needed for the driver balance
// calculation (spec 10.4), since a DRIVER- or SHARED-borne expense reduces
// what the company owes the driver, while a COMPANY-borne one doesn't.
enum ExpenseBearer {
  COMPANY
  DRIVER
  SHARED
}

enum SettlementStatus {
  PENDING
  PAID
  CANCELLED
}

enum WalletTopUpStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ComplaintCategory {
  DRIVER_BEHAVIOR
  VEHICLE_CONDITION
  PAYMENT
  SAFETY
  OTHER
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RideStatus {
  SCHEDULED
  REQUESTED
  ACCEPTED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// CASH/CARD are the only methods with real handling (cash collected
// directly by the driver; CARD via Stripe Checkout - see payment.controller.js).
// BANKILY/SEDAD/MASRIVI/CLICK/BIMBANK (spec 10.1, Mauritanian mobile-money
// apps) are declarative only - no gateway integration, just bookkeeping: the
// client transfers straight to the driver's own account (same money flow as
// CASH, the company never touches it), so settlement.service.js groups them
// with CASH, not with CARD - see DRIVER_COLLECTED_METHODS there. WALLET/
// COMPANY are kept grouped like CARD (company-side funds) and aren't
// currently reachable from the mobile client picker.
enum PaymentMethod {
  CASH
  CARD
  BANKILY
  SEDAD
  MASRIVI
  CLICK
  BIMBANK
  WALLET
  COMPANY
}

model User {
  id           String   @id @default(uuid())
  // Nullable as of the phone+OTP auth rollout - a CLIENT/DRIVER registered
  // via phone+OTP has neither an email nor a password (see auth.service.js's
  // requestOtp/verifyOtp/completeRegistration). ADMIN accounts (created only
  // via scripts/create-admin.js) and every legacy CLIENT/DRIVER row still
  // have both set - the invariant "email set <=> passwordHash set" is
  // enforced at the service layer, not the DB, and login() defensively
  // checks passwordHash before ever calling comparePassword.
  email        String?  @unique
  passwordHash String?
  fullName     String
  // Unique as of the phone+OTP auth rollout - it's now a login credential,
  // not just a contact field. See phone.util.js#normalizePhone for the
  // canonical +222XXXXXXXX format every write site normalizes through.
  // Shipped as its own migration after scripts/audit-and-normalize-phones.js
  // confirmed no duplicate/malformed values remained.
  phone        String?  @unique
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Set when the user deletes their account. The row is kept (anonymized,
  // not hard-deleted) so existing rides still resolve their counterpart's
  // name/rating - email/name/phone are scrubbed and the password hash is
  // replaced with an unusable random value at that point.
  deletedAt DateTime?

  // Driver-only fields. Left null for CLIENT rows. Kept on User (rather than a
  // separate DriverProfile table) because it's a strict 1:1 relation and
  // location pings are a high-frequency hot path where a join isn't worth it.
  isAvailable           Boolean?  @default(false)
  currentLat            Float?
  currentLng            Float?
  lastLocationUpdatedAt DateTime?

  // Vehicle info collected at driver registration. Plate is required for a
  // DRIVER (enforced in the registration validator, not the DB, since CLIENT/
  // ADMIN rows never have one); model is optional. Separate from the
  // admin-managed Vehicle/VehicleAssignment fleet records (see below) -
  // these stay as the mobile app's own self-reported fields, untouched by
  // the admin back office.
  vehiclePlate String?
  vehicleModel String?

  // Set to PENDING for a new DRIVER at registration, null for CLIENT/ADMIN.
  // A driver can't go online or accept rides until an admin sets this to
  // APPROVED (see user.service.js#updateAvailability, ride.service.js#acceptRide).
  // SUSPENDED/BLOCKED are admin-set operational states: both already fail the
  // `!== 'APPROVED'` checks above (blocking availability/ride-acceptance)
  // with no extra code; BLOCKED additionally denies login/refresh/requireAuth
  // entirely (see auth.service.js, auth.middleware.js).
  approvalStatus DriverApprovalStatus?
  approvedAt     DateTime?

  // Extended driver profile (admin back office, Phase 1). All optional -
  // existing rows get null until an admin fills them in.
  // Only set when different from `phone` (spec 4.1's "numéro WhatsApp si
  // différent") - null means "same as phone", not "no WhatsApp".
  whatsapp        String?
  address         String?
  nationalId      String?
  licenseNumber   String?
  licenseExpiryAt DateTime?
  contractType    String?
  // Captured once at driver creation as a historical record of the starting
  // balance; not editable afterward. The live, spendable balance is the
  // existing `creditBalance` field below, which this seeds at creation time.
  initialBalance  Float?    @default(0)

  // Verification documents (photo/ID/license) uploaded from the mobile app -
  // see DriverDocument. Deliberately NOT columns here: requireAuth
  // (auth.middleware.js) loads a full, unselected User row on every
  // authenticated request, so bytea blobs on this model would be pulled into
  // memory on every single API call app-wide.
  documents DriverDocument[]

  // Optional public-facing profile picture (either role) - separate from
  // DriverDocument, which is a private, admin-only verification file. Kept
  // off this model for the same requireAuth reason as documents above.
  avatar UserAvatar?

  // Driver's current commission rate (fraction 0..1, e.g. 0.20 = 20%).
  // Null for non-drivers. The only way this changes is
  // admin.service.js#setCommissionRate, which also writes a CommissionChange
  // row - so a ride's frozen commissionRateSnapshot (see Ride below) can
  // never silently drift out of sync with an unrecorded rate change.
  commissionRate Float?

  // Meaningful only for role=ADMIN (null for CLIENT/DRIVER). See AdminRole.
  adminRole AdminRole?

  // Running average across all ratings received (as a driver or as a client -
  // whichever role this user has). Updated incrementally when a rating comes in.
  ratingAverage Float?
  ratingCount   Int    @default(0)

  // Expo push token for this user's current device. Nullable - not every
  // user grants notification permission, and it's cleared on logout.
  pushToken String?

  // Referral program. This user's own shareable code (assigned at
  // registration; nullable rather than a NOT NULL migration since existing
  // rows are backfilled by a one-off script instead). referredById is set at
  // registration if they signed up with someone else's code.
  referralCode String? @unique
  referredById String?
  referredBy   User?   @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("Referrals")

  // Cash-equivalent balance, auto-applied to a future ride's cash payment
  // (see Ride.creditApplied). Funded by referral rewards.
  creditBalance           Float     @default(0)
  // Set once this user's own "referred friend's first ride" reward has been
  // granted, so it's never granted twice even across many later rides.
  referralRewardGrantedAt DateTime?

  ridesAsClient Ride[]         @relation("ClientRides")
  ridesAsDriver Ride[]         @relation("DriverRides")
  refreshTokens RefreshToken[]

  commissionChangesReceived CommissionChange[]  @relation("CommissionChangeDriver")
  commissionChangesMade     CommissionChange[]  @relation("CommissionChangeAdmin")
  vehicleAssignments        VehicleAssignment[]
  currentVehicles           Vehicle[]           @relation("VehicleCurrentDriver")
  adminActivityLogs         AdminActivityLog[]  @relation("AdminActivityLogAdmin")
  appSettingsUpdated        AppSetting[]        @relation("AppSettingUpdatedBy")

  expensesRecorded    Expense[]    @relation("ExpenseDriver")
  expensesCreated     Expense[]    @relation("ExpenseCreatedBy")
  settlementsAsDriver Settlement[] @relation("SettlementDriver")
  settlementsCreated  Settlement[] @relation("SettlementCreatedBy")
  settlementsPaid     Settlement[] @relation("SettlementPaidBy")

  walletTopUps          WalletTopUp[] @relation("WalletTopUpDriver")
  walletTopUpsConfirmed WalletTopUp[] @relation("WalletTopUpConfirmedBy")

  complaintsSubmitted Complaint[] @relation("ComplaintSubmittedBy")
  complaintsAbout     Complaint[] @relation("ComplaintAboutUser")
  complaintsResolved  Complaint[] @relation("ComplaintResolvedBy")

  @@index([role, isAvailable])
  @@map("users")
}

// A single verification document (photo/ID/license) for a DRIVER, uploaded
// from the mobile app and reviewed by an admin before approval. Stored as a
// blob directly in Postgres (small MVP driver count, no object-storage
// service to provision/manage) - kept off the User model itself, see the
// comment on User.documents above. data/mimeType are never selected by any
// list/detail endpoint that also returns other driver fields - only the
// dedicated GET .../documents/:type/file route reads them, to avoid dragging
// blobs into memory on unrelated requests.
model DriverDocument {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       DriverDocumentType
  data       Bytes
  mimeType   String
  uploadedAt DateTime           @default(now())

  @@unique([userId, type])
  @@map("driver_documents")
}

// A user's own profile picture (CLIENT or DRIVER, at most one each) - not
// gated by admin review like DriverDocument, and self-serve
// upload/replace/remove via GET/POST/DELETE .../me/avatar.
model UserAvatar {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data       Bytes
  mimeType   String
  uploadedAt DateTime @default(now())

  @@map("user_avatars")
}

// Audit trail of admin back-office actions (spec 13). Written by
// activityLog.service.js#logActivity, called from every mutating admin.*
// and vehicle.* service function - a plain append-only log, never updated
// or deleted. entityId is a loose reference (no FK) since the referenced
// row (a driver, vehicle, etc.) may itself later be archived or the id
// reused across entityTypes; details is a free-form snapshot of what
// changed, shaped differently per action.
model AdminActivityLog {
  id          String   @id @default(uuid())
  adminUserId String
  adminUser   User     @relation("AdminActivityLogAdmin", fields: [adminUserId], references: [id])
  action      String
  entityType  String
  entityId    String?
  details     Json?
  createdAt   DateTime @default(now())

  @@index([adminUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("admin_activity_logs")
}

// Generic key-value platform setting, admin-editable from the back office
// (e.g. the default commission rate seeded at driver creation - see
// appSetting.service.js). Extensible to future settings without a new
// migration each time; each reader is responsible for parsing `value` to the
// type it expects.
model AppSetting {
  id              String   @id @default(uuid())
  key             String   @unique
  value           String
  updatedAt       DateTime @updatedAt
  updatedByUserId String?
  updatedByUser   User?    @relation("AppSettingUpdatedBy", fields: [updatedByUserId], references: [id])

  @@map("app_settings")
}

// History of commissionRate changes on User (spec 9.3) - written every time
// admin.service.js#setCommissionRate changes a driver's rate, so past rate
// changes stay auditable even though User only stores the current rate.
model CommissionChange {
  id              String   @id @default(uuid())
  driverId        String
  driver          User     @relation("CommissionChangeDriver", fields: [driverId], references: [id])
  oldRate         Float?
  newRate         Float
  reason          String?
  changedByUserId String
  changedByUser   User     @relation("CommissionChangeAdmin", fields: [changedByUserId], references: [id])
  changedAt       DateTime @default(now())

  @@index([driverId])
  @@map("commission_changes")
}

// Admin-managed fleet record, additive next to User.vehiclePlate/vehicleModel
// (the mobile app's own self-reported fields, left untouched).
model Vehicle {
  id        String  @id @default(uuid())
  brand     String
  model     String
  plate     String  @unique
  color     String?
  year      Int?
  type      String?
  seatCount Int?

  insuranceProvider  String?
  insuranceNumber    String?
  insuranceExpiresAt DateTime?

  carteGriseNumber             String?
  technicalInspectionExpiresAt DateTime?

  // Spec 5.1's "propriétaire du véhicule" - a plain name, not a User FK: the
  // owner is often not the driver (e.g. a company or a third party who
  // leases the car to a driver), so there's no existing account to link to.
  ownerName String?

  status VehicleStatus @default(ACTIVE)

  // Denormalized "current driver" pointer for hot-path reads, kept in sync
  // exclusively by vehicle.service.js#assignVehicle/#unassignVehicle - the
  // source of truth for *history* is VehicleAssignment below.
  currentDriverId String?
  currentDriver   User?   @relation("VehicleCurrentDriver", fields: [currentDriverId], references: [id])

  assignments VehicleAssignment[]
  expenses    Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currentDriverId])
  @@map("vehicles")
}

// Operational expense (spec 6) - fuel, maintenance, insurance, salaries, etc.
// Kept separate from revenue.service.js's commission-based aggregates; its
// own getExpenseSummary aggregate lives in expense.service.js.
model Expense {
  id          String          @id @default(uuid())
  category    ExpenseCategory
  amount      Float
  description String?
  expenseDate DateTime        @default(now())

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])
  driverId  String?
  driver    User?    @relation("ExpenseDriver", fields: [driverId], references: [id])

  // Who bears this cost (spec 8.4). driverShareAmount is only meaningful
  // (and required, see expense.validators.js) when bearer=SHARED - the
  // portion of `amount` the driver bears; the rest is COMPANY's. For
  // bearer=DRIVER the driver's burden is the full `amount`, no separate
  // field needed. See expense.constants.js#getDriverBorneAmount.
  bearer            ExpenseBearer @default(COMPANY)
  driverShareAmount Float?

  receiptUrl      String?
  createdByUserId String
  createdByUser   User     @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([expenseDate])
  @@index([vehicleId])
  @@index([driverId])
  @@map("expenses")
}

// Periodic driver payout reconciliation (spec 8). Generated from completed
// rides in [periodStart, periodEnd) using the ride's frozen commission
// snapshot fields (never recomputed from the driver's *current* rate) -
// cashCommissionOwed is what the driver owes the company for CASH rides
// (they already collected the fare directly), cardNetOwed is what the
// company owes the driver for CARD/electronic rides (the company received
// the full fare). expensesOwed (spec 10.4/19.5) is the driver's share of
// expenses they bear (bearer=DRIVER/SHARED) over the same period - it also
// reduces what the company owes the driver, same direction as
// cashCommissionOwed. netAmount > 0 means the company pays the driver; < 0
// means the driver owes the company.
model Settlement {
  id                 String           @id @default(uuid())
  driverId           String
  driver             User             @relation("SettlementDriver", fields: [driverId], references: [id])
  periodStart        DateTime
  periodEnd          DateTime
  cashCommissionOwed Float
  cardNetOwed        Float
  expensesOwed       Float            @default(0)
  netAmount          Float
  status             SettlementStatus @default(PENDING)
  notes              String?

  createdByUserId String
  createdByUser   User      @relation("SettlementCreatedBy", fields: [createdByUserId], references: [id])
  paidAt          DateTime?
  paidByUserId    String?
  paidByUser      User?     @relation("SettlementPaidBy", fields: [paidByUserId], references: [id])
  createdAt       DateTime  @default(now())

  // Driver self-service "I paid" declaration when they owe the company
  // (netAmount < 0) - transferred via mobile money outside the app, same
  // manual pattern as a ride's declare/confirm flow (see
  // paymentMethod.util.js#MOBILE_MONEY_METHODS). Doesn't flip `status` on its
  // own - an admin still confirms via the existing markSettlementPaid.
  driverMarkedPaidAt  DateTime?
  driverPaymentMethod PaymentMethod?

  @@index([driverId])
  @@index([status])
  @@map("settlements")
}

// Driver self-service top-up of their own creditBalance (see User.creditBalance) -
// just a tracked balance for now, with no automatic effect on settlements.
// CARD goes through Stripe Checkout exactly like a ride's card payment -
// confirmed automatically by the webhook (payment.controller.js), never by an
// admin. Mobile-money methods are declare/confirm, same manual two-step shape
// as Settlement's driverMarkedPaidAt/markSettlementPaid, except there's no
// pre-existing admin-created row to declare against - driverDeclaredAt is set
// at creation time here, since the driver picks amount+method and "declares"
// in one step.
model WalletTopUp {
  id       String @id @default(uuid())
  driverId String
  driver   User   @relation("WalletTopUpDriver", fields: [driverId], references: [id])

  amount Float
  method PaymentMethod
  status WalletTopUpStatus @default(PENDING)

  driverDeclaredAt DateTime?

  confirmedAt       DateTime?
  confirmedByUserId String?
  confirmedByUser   User?     @relation("WalletTopUpConfirmedBy", fields: [confirmedByUserId], references: [id])

  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  createdAt DateTime @default(now())

  @@index([driverId])
  @@index([status])
  @@map("wallet_topups")
}

// Client/driver-submitted complaint (spec 12), managed from the admin back
// office. submittedByUser is whoever filed it (either role); aboutUser is
// optional (e.g. a client complaining about a specific driver); rideId ties
// it to the ride in question when relevant.
model Complaint {
  id                String            @id @default(uuid())
  submittedByUserId String
  submittedByUser   User              @relation("ComplaintSubmittedBy", fields: [submittedByUserId], references: [id])
  aboutUserId       String?
  aboutUser         User?             @relation("ComplaintAboutUser", fields: [aboutUserId], references: [id])
  rideId            String?
  ride              Ride?             @relation(fields: [rideId], references: [id])
  category          ComplaintCategory
  description       String
  status            ComplaintStatus   @default(OPEN)
  adminNotes        String?

  resolvedByUserId String?
  resolvedByUser   User?     @relation("ComplaintResolvedBy", fields: [resolvedByUserId], references: [id])
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([submittedByUserId])
  @@index([rideId])
  @@map("complaints")
}

// Vehicle<->driver assignment history (spec 5.3). Assigning a vehicle closes
// any row with endDate: null for that vehicle, then opens a new one - see
// vehicle.service.js#assignVehicle.
model VehicleAssignment {
  id        String    @id @default(uuid())
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId  String
  driver    User      @relation(fields: [driverId], references: [id])
  startDate DateTime  @default(now())
  endDate   DateTime?
  notes     String?
  createdAt DateTime  @default(now())

  @@index([driverId])
  @@index([vehicleId, endDate])
  @@map("vehicle_assignments")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// One-time codes for the phone+OTP auth flow (see
// phoneOtp.service.js/auth.service.js#requestOtp/verifyOtp). Deliberately not
// tied to User by FK - a code can be requested for a phone number that
// doesn't have an account yet (new registration), same reason RefreshToken's
// tokenHash pattern is reused here (codeHash, never the plaintext code).
model PhoneOtp {
  id         String    @id @default(uuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
  @@map("phone_otps")
}

model Ride {
  id       String  @id @default(uuid())
  clientId String
  client   User    @relation("ClientRides", fields: [clientId], references: [id])
  driverId String?
  driver   User?   @relation("DriverRides", fields: [driverId], references: [id])

  status RideStatus @default(REQUESTED)

  pickupLat            Float
  pickupLng            Float
  pickupAddress        String?
  // Arabic variant, filled in asynchronously after the ride is created (see
  // ride.service.js#enrichRideAddressesInArabic) - Nominatim only returns one
  // language per request, so this lags slightly behind pickupAddress rather
  // than blocking ride creation on a second serialized geocode call.
  pickupAddressAr      String?
  destinationLat       Float
  destinationLng       Float
  destinationAddress   String?
  destinationAddressAr String?

  distanceKm    Float?
  durationMin   Float?
  estimatedFare Float?
  // Road-network route from OSRM as an array of [lat, lng] pairs, for drawing
  // the actual path on the map. Null if OSRM was unreachable when the ride
  // was requested (distance/duration then fall back to a straight-line estimate).
  routeGeometry Json?

  // Set only for a booked-ahead ride (status starts at SCHEDULED). Null for
  // an immediate request. The scheduling job (src/jobs/scheduling.job.js)
  // flips SCHEDULED -> REQUESTED (and resets requestedAt to that moment) once
  // within SCHEDULED_RIDE_ACTIVATION_LEAD_MIN of this time, at which point it
  // behaves exactly like a normal ride request.
  scheduledFor DateTime?

  requestedAt DateTime  @default(now())
  acceptedAt  DateTime?
  arrivedAt   DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  cancelledBy        Role?
  cancellationReason String?

  // Drivers who declined this ride (see ride.service.js#declineRide). Status
  // stays REQUESTED - a decline only hides the request from that one driver,
  // it doesn't remove it for the other nearby drivers it was broadcast to.
  declinedByDriverIds String[] @default([])

  // Chosen by the client at request time. Still no online gateway - the
  // driver confirms collection manually either way, this just records intent.
  paymentMethod PaymentMethod @default(CASH)

  // The driver marks a completed ride as paid once they've collected payment
  // in person (CASH rides). For CARD rides, isPaid/paidAt are instead set by
  // the Stripe webhook once the client completes an online Checkout Session.
  // For mobile-money rides (BANKILY/SEDAD/MASRIVI/CLICK/BIMBANK - no gateway
  // API, see paymentMethod.util.js), isPaid/paidAt are only set once the
  // driver confirms via confirmRidePaymentReceived, itself gated on the
  // client having first declared payment below.
  isPaid Boolean   @default(false)
  paidAt DateTime?

  // Client-side "I paid" declaration for a mobile-money ride - step 1 of that
  // two-step flow (see ride.service.js#declareRidePaidByClient). Null until
  // the client taps "J'ai payé"; isPaid/paidAt above only flip once the
  // driver then confirms receipt.
  clientMarkedPaidAt DateTime?

  // Set once the client starts (session id) / completes (payment intent id) a
  // Stripe Checkout Session for this ride. Null for CASH rides and for CARD
  // rides where payment hasn't been attempted yet.
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String? @unique

  // How much of the client's referral credit balance was auto-deducted
  // toward this ride at completion - the driver should only collect
  // (estimatedFare - creditApplied) in cash, not the full estimate.
  creditApplied Float @default(0)

  // Frozen at the moment this ride reaches COMPLETED (see
  // ride.service.js#snapshotCommission), using the driver's commissionRate
  // AT THAT MOMENT - a later change to the driver's rate must never
  // retroactively alter an already-completed ride's numbers. Stored as real
  // columns (not derived at read time) so admin.service.js's revenue
  // aggregates can _sum them directly. commissionAmount is the company's
  // cut, driverNetAmount = estimatedFare - commissionAmount.
  commissionRateSnapshot Float?
  commissionAmount       Float?
  driverNetAmount        Float?

  // Per-user "trash": hiding a ride only removes it from that user's own
  // history list, the other participant and the ride record are unaffected.
  hiddenByClient Boolean @default(false)
  hiddenByDriver Boolean @default(false)

  // driverRating/-Comment = rating the CLIENT gave the DRIVER; clientRating/-Comment
  // = rating the DRIVER gave the CLIENT. Each side rates the other at most once,
  // only after the ride reaches COMPLETED.
  driverRating        Int?
  driverRatingComment String?
  clientRating        Int?
  clientRatingComment String?

  // Set once the periodic reminder job (see src/jobs/reminder.job.js) has
  // actually sent that reminder push, so a ride is only ever nudged once.
  searchReminderSentAt DateTime?
  ratingReminderSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  complaints Complaint[]

  @@index([status])
  @@index([clientId])
  @@index([driverId])
  @@index([driverId, completedAt])
  @@map("rides")
}
