# Copy this file to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

# Supabase: Project Settings -> Database -> Connection string
# Pooled connection (port 6543, via PgBouncer) - used by the running app
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true
# Direct connection (port 5432) - used only by `prisma migrate`
DIRECT_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# Access token lifetime - kept short since refresh tokens (below) renew it.
JWT_EXPIRES_IN=15m
# Refresh token lifetime, in days. Refresh tokens are opaque, DB-backed, and
# rotated on every use (see auth.service.js).
REFRESH_TOKEN_TTL_DAYS=30

# Not read by any code - routing uses OSRM below, not Google. Leave blank.
GOOGLE_MAPS_API_KEY=

# Real road-network routing (distance/duration/route line). Public demo server
# by default - fine for dev, not for production load. Point at your own
# self-hosted OSRM instance for anything beyond MVP testing.
OSRM_BASE_URL=https://router.project-osrm.org

# Ride matching / fare estimation tuning
SEARCH_RADIUS_KM=5
BASE_FARE=2.5
RATE_PER_KM=1.2
RATE_PER_MIN=0.2

# Set to your mobile app's dev origin, or * for local development
CORS_ORIGIN=*

# Stripe (test mode) - online card payment for CARD-method rides. Leave blank
# to run without it configured (the checkout-session endpoint then returns a
# clear 503 instead of attempting a payment). Get test keys from
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# From the Stripe CLI (`stripe listen --forward-to localhost:3000/api/webhooks/stripe`)
# while developing, or the webhook endpoint's settings page in the dashboard
# once deployed.
STRIPE_WEBHOOK_SECRET=
# Stripe test mode doesn't support MRU (Mauritanian Ouguiya) - use a
# Stripe-supported currency for now.
STRIPE_CURRENCY=usd
