# Copy to .env.development.local (not .env.local!) to reach a locally
# running backend on a different port during `npm run dev`. The
# .env.development.local name matters: Vite only loads it in development
# mode, whereas a plain .env.local loads for every mode including
# `vite build` - that footgun once baked this localhost URL straight into a
# production admin bundle, breaking every fetch() in prod ("Failed to
# fetch"). Production builds always want a blank base URL, since the built
# app is served same-origin from the backend at /admin (plain relative
# /api/... requests, no CORS needed) - so never rename this back to
# .env.local.
VITE_API_BASE_URL=http://localhost:3000
