# Copy this file to .env. Expo/Metro inlines EXPO_PUBLIC_* vars automatically.
# After changing this, restart with: npx expo start -c

# Pick the one that matches how you're running the app:
#   Physical phone via Expo Go, same Wi-Fi as this machine (default):
EXPO_PUBLIC_API_URL=http://192.168.100.5:3000
#   Android emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
#   iOS simulator or web:
# EXPO_PUBLIC_API_URL=http://localhost:3000
